rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/history
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - The UID of the user
    //   - topicDetected: string (required) - Detected topic
    //   - summary: string (required) - Summary of the note
    //   - keywords: list of strings (required) - Extracted keywords
    //   - questions: string (required) - JSON stringified questions
    //   - timestamp: number (required, immutable) - Time of analysis
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidHistoryItem(data, userId) {
      return hasRequiredFields(['userId', 'topicDetected', 'summary', 'keywords', 'questions', 'timestamp']) &&
             hasOnlyAllowedFields(['userId', 'topicDetected', 'summary', 'keywords', 'questions', 'timestamp']) &&
             data.userId == userId &&
             data.topicDetected is string && data.topicDetected.size() > 0 && data.topicDetected.size() < 500 &&
             data.summary is string && data.summary.size() > 0 && data.summary.size() < 5000 &&
             data.keywords is list && data.keywords.size() <= 50 &&
             data.questions is string && data.questions.size() < 1000000 &&
             data.timestamp is number;
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /classrooms/{code} {
      allow get: if isAuthenticated();
      // Allow querying classrooms; restricted by creatorUid filter in the client
      allow list: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.creatorUid == request.auth.uid;
    }

    match /global_cache/{id} {
      allow read: if isAuthenticated();
    }

    match /community_library/{id} {
      allow read: if isAuthenticated();
    }
  }
}
