# ─── AI APIs (server-side only — never exposed to browser) ─────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Alias used by this project for Gemini:
chem1=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Payments (Razorpay) ───────────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# Key ID is safe to expose (it goes to the browser via /api/config)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ─── Firebase (frontend — these are public by design) ─────────────────────
# These go in your src/lib/firebase.ts config object, NOT as env vars
# FIREBASE_API_KEY, FIREBASE_PROJECT_ID, etc.

# ─── Runtime ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Scan Cost Controls ───────────────────────────────────────────────────
# Keep these defaults for low-cost scans (target <= ₹3 per scan).
MAX_SCAN_COST_INR=3
GEMINI_COST_BUFFER_INR=0.8
USD_TO_INR=85
TAVILY_CREDIT_USD=0.008
MAX_TAVILY_QUERIES=5
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=20
MAX_TOPUP_ATTEMPTS=1
SUPPLEMENTAL_TAVILY_QUERIES=2
MIN_STRUCTURED_SOURCES=8
DRY_RUN=false

# ─── Rate Limiting (in-memory single-instance) ──────────────────────────
# This project uses a simple in-memory rate limiter for the staging deployment.
# For production-scale, replace with a managed Redis and corresponding logic.

# Public app URL (used for API base in some deployments)
# Set this to your Cloud Run staging URL when deploying.
PUBLIC_APP_URL=https://chemscan-49989755678.us-central1.run.app/

# ─── Notes ────────────────────────────────────────────────────────────────
# Stripe has been replaced by Razorpay.
# Firebase Admin SDK uses Application Default Credentials on GCP Cloud Run.
# On local dev: set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON path.
