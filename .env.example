# GEMINI_API_KEY: Required for Gemini AI API calls (image analysis + question generation).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# chem1: Alternative name for GEMINI_API_KEY (used if GEMINI_API_KEY is not set).
chem1="MY_GEMINI_API_KEY"

# TAVILY_API_KEY: Required for web search (fetching real exam questions).
# Get a free key at https://tavily.com
TAVILY_API_KEY="MY_TAVILY_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# STRIPE_SECRET_KEY: Required for Stripe payments (Premium upgrade).
STRIPE_SECRET_KEY="MY_STRIPE_SECRET_KEY"
